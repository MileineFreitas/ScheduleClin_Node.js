generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(uuid()) @db.Char(36)
  userName             String?   @map("UserName") @db.VarChar(256)
  normalizedUserName   String?   @unique @map("NormalizedUserName") @db.VarChar(256)
  email                String?   @map("Email") @db.VarChar(256)
  normalizedEmail      String?   @map("NormalizedEmail") @db.VarChar(256)
  emailConfirmed       Boolean   @default(false) @map("EmailConfirmed")
  passwordHash         String?   @map("PasswordHash") @db.Text
  securityStamp        String?   @map("SecurityStamp") @db.Text
  concurrencyStamp     String?   @map("ConcurrencyStamp") @db.Text
  phoneNumber          String?   @map("PhoneNumber") @db.Text
  phoneNumberConfirmed Boolean   @default(false) @map("PhoneNumberConfirmed")
  twoFactorEnabled     Boolean   @default(false) @map("TwoFactorEnabled")
  lockoutEnd           DateTime? @map("LockoutEnd")
  lockoutEnabled       Boolean   @default(true) @map("LockoutEnabled")
  accessFailedCount    Int       @default(0) @map("AccessFailedCount")
  cpf                  String?   @map("CPF") @db.VarChar(14)
  perfilId             String?   @map("PerfilId") @db.Char(36)
  crp                  String?   @map("Crp") @db.VarChar(20)
  dataNascimento       DateTime  @map("DataNascimento")
  createAt             DateTime  @default(now()) @map("CreateAt")
  mustChangePassword   Boolean   @default(true) @map("MustChangePassword")
  active               Boolean   @default(true) @map("Active")

  perfil    Profile?   @relation(fields: [perfilId], references: [profileId], onDelete: NoAction, onUpdate: NoAction)
  userRoles UserRole[]

  @@map("AspNetUsers")
}

model Role {
  id               String     @id @default(uuid()) @db.Char(36)
  name             String?    @map("Name") @db.VarChar(256)
  normalizedName   String?    @unique @map("NormalizedName") @db.VarChar(256)
  concurrencyStamp String?    @map("ConcurrencyStamp") @db.Text
  userRoles        UserRole[]

  @@map("AspNetRoles")
}

model UserRole {
  userId String @map("UserId") @db.Char(36)
  roleId String @map("RoleId") @db.Char(36)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("AspNetUserRoles")
}

model Profile {
  profileId   String  @id @default(uuid()) @map("ProfileId") @db.Char(36)
  name        String  @db.Text
  description String? @db.Text
  crp         Int?    @map("CRP")

  users User[]

  @@map("Profiles")
}

model Calendar {
  calendarID      String   @id @default(uuid()) @map("CalendarID") @db.Char(36)
  title           String   @map("Title") @db.Text
  createAt        DateTime @default(now()) @map("CreateAt")
  scheduleDate    DateTime @map("ScheduleDate")
  durationMinutes Int      @default(60) @map("DurationMinutes")
  pacienteId      String?  @map("PacienteId") @db.Char(36)
  psicologoId     String?  @map("PsicologoId") @db.Char(36)
  status          String   @default("Confirmada") @map("Status") @db.VarChar(30)
  criadoPorId     String?  @map("CriadoPorId") @db.Char(36)

  @@map("Calendars")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Char(36)
  dateUtc   DateTime @default(now()) @map("DateUtc")
  userId    String?  @map("UserId") @db.Char(36)
  userName  String?  @map("UserName") @db.VarChar(256)
  action    String   @map("Action") @db.VarChar(80)
  entity    String?  @map("Entity") @db.VarChar(80)
  entityId  String?  @map("EntityId") @db.VarChar(80)
  details   String?  @map("Details") @db.VarChar(1000)
  ipAddress String?  @map("IpAddress") @db.VarChar(64)

  @@map("AuditLogs")
}
