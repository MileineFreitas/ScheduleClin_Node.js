# SQL Server connection string (Prisma format)
DATABASE_URL="sqlserver://localhost:1433;database=ScheduleClin;user=sa;password=YourPassword;trustServerCertificate=true"

# Session secret (change in production)
SESSION_SECRET=change-me-to-a-long-random-string

# Server
PORT=3000
NODE_ENV=development

# Cookie secure flag (true in production with HTTPS)
COOKIE_SECURE=false
