# MariaDB / MySQL (XAMPP ou MySQL local) — formato Prisma
# XAMPP padrão: usuário root, senha vazia
DATABASE_URL="mysql://root:@localhost:3307/scheduleclin"
#
# Com senha no root:
# DATABASE_URL="mysql://root:SUA_SENHA@localhost:3306/scheduleclin"

# Session secret (change in production)
SESSION_SECRET=change-me-to-a-long-random-string

# Server
PORT=3000
NODE_ENV=development

# Cookie secure flag (true in production with HTTPS)
COOKIE_SECURE=false
